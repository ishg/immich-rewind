# Copy this file to .env.local and fill in your values
IMMICH_SERVER_URL=https://immich.box
IMMICH_API_KEY=your_api_key_here
# Public URL used by the browser to build links back to Immich
# Usually the same as IMMICH_SERVER_URL unless your internal/external URLs differ
NEXT_PUBLIC_IMMICH_URL=https://immich.box
